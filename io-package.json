{
  "common": {
    "name": "drq",
    "version": "0.4.1",
    "news": {
      "0.4.1": {
        "en": "Add Blockly-friendly send commands for info, warn and alarm via sendTo",
        "de": "Fuegt Blockly-freundliche Sendekommandos fuer Info, Warnung und Alarm per sendTo hinzu"
      },
      "0.4.0": {
        "en": "Add inbox polling and receive datapoints for incoming DRQ messages",
        "de": "Fuegt Inbox-Polling und Empfangs-Datenpunkte fuer eingehende DRQ-Nachrichten hinzu"
      },
      "0.3.0": {
        "en": "Add dedicated direct datapoints for info, warn and alarm messages",
        "de": "Fuegt eigene Direkt-Datenpunkte fuer Info-, Warn- und Alarm-Nachrichten hinzu"
      },
      "0.2.1": {
        "en": "Add a test send button to the admin configuration",
        "de": "Fuegt einen Test-Senden-Button in der Admin-Konfiguration hinzu"
      },
      "0.2.0": {
        "en": "Add test send states and adapter workbench controls for easier manual testing",
        "de": "Fuegt Test-Send-States und Adapter-Werkzeuge fuer einfachere manuelle Tests hinzu"
      },
      "0.1.2": {
        "en": "Add send.direct for immediate sending when the datapoint is written",
        "de": "Fuegt send.direct fuer sofortiges Senden beim Beschreiben des Datenpunkts hinzu"
      },
      "0.1.0": {
        "en": "Add writable send states for text, recipients, title, severity and trigger-based sending",
        "de": "Fuegt beschreibbare Send-States fuer Text, Empfaenger, Titel, Schweregrad und Trigger-Versand hinzu"
      },
      "0.0.3": {
        "en": "Enable messagebox support for sendTo and improve adapter metadata",
        "de": "Aktiviert messagebox fuer sendTo und verbessert die Adapter-Metadaten"
      },
      "0.0.2": {
        "en": "Fix jsonConfig validation and create info states explicitly on startup",
        "de": "Behebt jsonConfig-Validierung und legt info-States beim Start explizit an"
      },
      "0.0.1": {
        "en": "Initial adapter scaffold with DRQ sendTo integration",
        "de": "Erstes Adapter-Grundgeruest mit DRQ-sendTo-Integration"
      }
    },
    "titleLang": {
      "en": "DRQ",
      "de": "DRQ"
    },
    "desc": {
      "en": "Send and receive DRQ messenger messages from ioBroker",
      "de": "DRQ-Messenger-Nachrichten aus ioBroker senden und empfangen"
    },
    "authors": [
      "OpenAI Codex"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "type": "communication",
    "icon": "drq-logo.svg",
    "enabled": true,
    "messagebox": true,
    "extIcon": "https://raw.githubusercontent.com/Manemm2103/iobroker.drq/main/admin/drq-logo.svg",
    "readme": "https://github.com/Manemm2103/iobroker.drq/blob/main/README.md",
    "loglevel": "info",
    "compact": true,
    "connectionType": "local",
    "dataSource": "push",
    "materialize": true,
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=5.0.19"
      }
    ],
    "globalDependencies": []
  },
  "native": {
    "baseUrl": "",
    "apiKey": "",
    "defaultRecipients": "",
    "sourceName": "ioBroker",
    "timeoutMs": 10000,
    "pollIntervalMs": 15000
  },
