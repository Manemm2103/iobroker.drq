{
  "common": {
    "name": "drq",
    "version": "0.1.2",
    "news": {
      "0.1.2": {
        "en": "Add send.direct for immediate sending when the datapoint is written",
        "de": "Fuegt send.direct fuer sofortiges Senden beim Beschreiben des Datenpunkts hinzu"
      },
      "0.1.0": {
        "en": "Add writable send states for text, recipients, title, severity and trigger-based sending",
        "de": "Fuegt beschreibbare Send-States fuer Text, Empfaenger, Titel, Schweregrad und Trigger-Versand hinzu"
      },
      "0.0.3": {
        "en": "Enable messagebox support for sendTo and improve adapter metadata",
        "de": "Aktiviert messagebox fuer sendTo und verbessert die Adapter-Metadaten"
      },
      "0.0.2": {
        "en": "Fix jsonConfig validation and create info states explicitly on startup",
        "de": "Behebt jsonConfig-Validierung und legt info-States beim Start explizit an"
      },
      "0.0.1": {
        "en": "Initial adapter scaffold with DRQ sendTo integration",
        "de": "Erstes Adapter-Grundgeruest mit DRQ-sendTo-Integration"
      }
    },
    "titleLang": {
      "en": "DRQ",
      "de": "DRQ"
    },
    "desc": {
      "en": "Send status messages from ioBroker to DRQ users",
      "de": "Statusmeldungen aus ioBroker an DRQ-Benutzer senden"
    },
    "authors": [
      "OpenAI Codex"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "type": "communication",
    "icon": "drq-logo.svg",
    "enabled": true,
    "messagebox": true,
    "extIcon": "https://raw.githubusercontent.com/Manemm2103/iobroker.drq/main/admin/drq-logo.svg",
    "readme": "https://github.com/Manemm2103/iobroker.drq/blob/main/README.md",
    "loglevel": "info",
    "compact": true,
    "connectionType": "local",
    "dataSource": "push",
    "materialize": true,
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=5.0.19"
      }
    ],
    "globalDependencies": []
  },
  "native": {
    "baseUrl": "",
    "apiKey": "",
    "defaultRecipients": "",
    "sourceName": "ioBroker",
    "timeoutMs": 10000
  },
  "objects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "If connected to DRQ",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "info.lastMessage",
      "type": "state",
      "common": {
        "name": "Last message text",
        "type": "string",
        "role": "text",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "info.lastResult",
      "type": "state",
      "common": {
        "name": "Last send result",
        "type": "string",
        "role": "json",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "info.lastError",
      "type": "state",
      "common": {
        "name": "Last send error",
        "type": "string",
        "role": "text",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "send",
      "type": "channel",
      "common": {
        "name": "Send"
      },
      "native": {}
    },
    {
      "_id": "send.text",
      "type": "state",
      "common": {
        "name": "Message text",
        "type": "string",
        "role": "text",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "send.direct",
      "type": "state",
      "common": {
        "name": "Direct message",
        "type": "string",
        "role": "text",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "send.recipients",
      "type": "state",
      "common": {
        "name": "Recipients",
        "type": "string",
        "role": "text",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "send.title",
      "type": "state",
      "common": {
        "name": "Message title",
        "type": "string",
        "role": "text",
        "read": true,
        "write": true,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "send.severity",
      "type": "state",
      "common": {
        "name": "Severity",
        "type": "string",
        "role": "text",
        "read": true,
        "write": true,
        "def": "info",
        "states": {
          "info": "info",
          "warn": "warn",
          "alarm": "alarm"
        }
      },
      "native": {}
    },
    {
      "_id": "send.trigger",
      "type": "state",
      "common": {
        "name": "Send trigger",
        "type": "boolean",
        "role": "button",
        "read": false,
        "write": true,
        "def": false
      },
      "native": {}
    }
  ]
}
