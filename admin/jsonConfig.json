{
  "i18n": true,
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": "Main settings",
      "items": {
        "baseUrl": {
          "newLine": true,
          "type": "text",
          "label": "DRQ base URL",
          "help": "Example: https://drq.example.com",
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "apiKey": {
          "newLine": true,
          "type": "password",
          "label": "API key",
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "defaultRecipients": {
          "newLine": true,
          "type": "textarea",
          "label": "Default DRQ recipients",
          "help": "Comma, semicolon or line separated UIN values",
          "minRows": 3,
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "sourceName": {
          "newLine": true,
          "type": "text",
          "label": "Source label",
          "help": "Shown inside DRQ as the source of the message",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "timeoutMs": {
          "newLine": true,
          "type": "number",
          "label": "HTTP timeout (ms)",
          "min": 1000,
          "step": 500,
          "sm": 12,
          "md": 6,
          "lg": 6
        }
      }
    }
  }
}

